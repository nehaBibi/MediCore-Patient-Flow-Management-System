@{
    Layout = null;
}
<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>MediCore PatientFlow</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <style>
        :root {
            --ink: #112E81;
            --violet: #4647AE;
            --blue: #4382DF;
            --mist: #AACCD6;
            --surface: #ffffff;
            --soft: #F5F9FC;
            --text: #17213A;
            --muted: #6F7C95;
            --line: rgba(17, 46, 129, .12);
            --shadow: 0 18px 45px rgba(17, 46, 129, .12);
        }

        * {
            letter-spacing: 0;
        }

        body {
            min-height: 100vh;
            margin: 0;
            color: var(--text);
            background:
                radial-gradient(circle at top left, rgba(170, 204, 214, .45), transparent 32rem),
                linear-gradient(135deg, #F8FBFD 0%, #EEF5FB 48%, #F7FAFF 100%);
            font-family: "Segoe UI", system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
        }

        .app-shell {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 280px;
            flex: 0 0 280px;
            padding: 1.25rem;
            color: #fff;
            background: linear-gradient(180deg, var(--ink), var(--violet));
            box-shadow: 12px 0 35px rgba(17, 46, 129, .2);
            position: sticky;
            top: 0;
            height: 100vh;
        }

        .brand-mark {
            display: flex;
            align-items: center;
            gap: .75rem;
            padding: .65rem .5rem 1.25rem;
            color: #fff;
            text-decoration: none;
        }

        .brand-icon {
            width: 44px;
            height: 44px;
            display: grid;
            place-items: center;
            border-radius: 8px;
            background: rgba(255, 255, 255, .14);
            box-shadow: inset 0 0 0 1px rgba(255, 255, 255, .2);
            font-weight: 800;
        }

        .brand-copy strong {
            display: block;
            font-size: 1.05rem;
            line-height: 1;
        }

        .brand-copy span,
        .nav-section {
            color: rgba(255, 255, 255, .68);
            font-size: .78rem;
        }

        .nav-section {
            padding: 1rem .75rem .4rem;
            text-transform: uppercase;
            font-weight: 700;
        }

        .side-nav {
            display: grid;
            gap: .4rem;
        }

        .side-link {
            display: flex;
            align-items: center;
            gap: .7rem;
            min-height: 44px;
            padding: .65rem .8rem;
            border-radius: 8px;
            color: rgba(255, 255, 255, .82);
            text-decoration: none;
            font-weight: 600;
            transition: background .18s ease, color .18s ease, transform .18s ease;
        }

        .side-link:hover,
        .side-link:focus {
            color: #fff;
            background: rgba(255, 255, 255, .13);
            transform: translateX(2px);
        }

        .side-icon {
            width: 30px;
            height: 30px;
            display: grid;
            place-items: center;
            border-radius: 8px;
            background: rgba(170, 204, 214, .18);
            color: #fff;
            font-size: .78rem;
            font-weight: 800;
        }

        .sidebar-card {
            margin-top: 1.4rem;
            padding: 1rem;
            border-radius: 8px;
            background: rgba(255, 255, 255, .12);
            box-shadow: inset 0 0 0 1px rgba(255, 255, 255, .16);
        }

        .sidebar-card p {
            margin: 0;
            color: rgba(255, 255, 255, .76);
            font-size: .9rem;
        }

        .main-panel {
            flex: 1;
            min-width: 0;
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 1rem 1.6rem;
            background: rgba(255, 255, 255, .78);
            border-bottom: 1px solid var(--line);
            backdrop-filter: blur(12px);
            position: sticky;
            top: 0;
            z-index: 5;
        }

        .topbar-title {
            margin: 0;
            color: var(--ink);
            font-size: 1rem;
            font-weight: 800;
        }

        .login-link {
            display: inline-flex;
            align-items: center;
            min-height: 40px;
            padding: .5rem .9rem;
            border-radius: 8px;
            color: var(--ink);
            background: rgba(170, 204, 214, .24);
            text-decoration: none;
            font-weight: 700;
        }

        .content-wrap {
            width: min(1180px, calc(100% - 2rem));
            margin: 0 auto;
            padding: 1.6rem 0 2.5rem;
        }

        .page-hero {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 1rem;
            align-items: center;
            margin-bottom: 1.25rem;
            padding: 1.45rem;
            border-radius: 8px;
            color: #fff;
            background:
                linear-gradient(135deg, rgba(17, 46, 129, .98), rgba(67, 130, 223, .9)),
                var(--ink);
            box-shadow: var(--shadow);
            overflow: hidden;
            position: relative;
        }

        .page-hero::after {
            content: "";
            position: absolute;
            right: -4rem;
            bottom: -6rem;
            width: 18rem;
            height: 18rem;
            border: 2.5rem solid rgba(170, 204, 214, .2);
            border-radius: 50%;
        }

        .page-hero > * {
            position: relative;
            z-index: 1;
        }

        .eyebrow {
            margin: 0 0 .35rem;
            color: rgba(255, 255, 255, .74);
            font-size: .78rem;
            font-weight: 800;
            text-transform: uppercase;
        }

        .page-title {
            margin: 0;
            font-size: clamp(1.65rem, 4vw, 2.75rem);
            font-weight: 800;
            line-height: 1.08;
        }

        .page-subtitle {
            max-width: 48rem;
            margin: .65rem 0 0;
            color: rgba(255, 255, 255, .78);
        }

        .metric-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
            gap: 1rem;
            margin-bottom: 1.25rem;
        }

        .metric-card,
        .content-card {
            border: 1px solid var(--line);
            border-radius: 8px;
            background: rgba(255, 255, 255, .88);
            box-shadow: var(--shadow);
        }

        .metric-card {
            padding: 1.2rem;
        }

        .metric-label {
            margin: 0;
            color: var(--muted);
            font-size: .82rem;
            font-weight: 800;
            text-transform: uppercase;
        }

        .metric-value {
            margin: .45rem 0 0;
            color: var(--ink);
            font-size: 2rem;
            font-weight: 800;
            line-height: 1;
        }

        .content-card {
            padding: 1.15rem;
            overflow: hidden;
        }

        .toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .section-title {
            margin: 0;
            color: var(--ink);
            font-size: 1.15rem;
            font-weight: 800;
        }

        .btn-primary,
        .btn-success {
            border: 0;
            background: linear-gradient(135deg, var(--violet), var(--blue));
            box-shadow: 0 10px 22px rgba(67, 130, 223, .26);
            font-weight: 700;
        }

        .btn-primary:hover,
        .btn-success:hover {
            background: linear-gradient(135deg, var(--ink), var(--blue));
        }

        .btn-secondary {
            border: 0;
            background: rgba(70, 71, 174, .12);
            color: var(--violet);
            font-weight: 700;
        }

        .btn-danger {
            border: 0;
            background: #E84C5F;
            font-weight: 700;
        }

        .table {
            margin-bottom: 0;
            vertical-align: middle;
        }

        .table thead th {
            border: 0;
            color: var(--ink);
            background: rgba(170, 204, 214, .24);
            font-size: .78rem;
            text-transform: uppercase;
        }

        .table tbody td {
            border-color: rgba(17, 46, 129, .08);
            padding: .85rem .5rem;
        }

        .badge-soft {
            display: inline-flex;
            align-items: center;
            min-height: 30px;
            padding: .35rem .65rem;
            border-radius: 999px;
            color: var(--ink);
            background: rgba(170, 204, 214, .32);
            font-weight: 800;
        }

        .form-control,
        .form-select {
            min-height: 46px;
            border-color: var(--line);
            border-radius: 8px;
            background-color: rgba(255, 255, 255, .9);
        }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--blue);
            box-shadow: 0 0 0 .2rem rgba(67, 130, 223, .16);
        }

        .form-label {
            color: var(--ink);
            font-weight: 700;
        }

        .empty-state {
            padding: 2rem;
            text-align: center;
            color: var(--muted);
        }

        @@media (max-width: 900px) {
            .app-shell {
                display: block;
            }

            .sidebar {
                width: 100%;
                height: auto;
                position: relative;
            }

            .side-nav {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .sidebar-card {
                display: none;
            }

            .page-hero,
            .toolbar {
                grid-template-columns: 1fr;
                align-items: stretch;
            }
        }

        @@media (max-width: 560px) {
            .side-nav {
                grid-template-columns: 1fr;
            }

            .topbar,
            .page-hero,
            .content-card {
                padding: 1rem;
            }

            .table-responsive {
                border-radius: 8px;
            }
        }
    </style>
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar">
            <a class="brand-mark" href="/">
                <span class="brand-icon">M+</span>
                <span class="brand-copy">
                    <strong>MediCore</strong>
                    <span>PatientFlow</span>
                </span>
            </a>
            <div class="nav-section">Hospital Desk</div>
            <nav class="side-nav" aria-label="Main navigation">
                <a class="side-link" href="/">
                    <span class="side-icon">DB</span>
                    Dashboard
                </a>
                <a class="side-link" href="/Departments">
                    <span class="side-icon">DP</span>
                    Departments
                </a>
                <a class="side-link" href="/Patients">
                    <span class="side-icon">PT</span>
                    Patients
                </a>
                <a class="side-link" href="/Admissions">
                    <span class="side-icon">AD</span>
                    Admissions
                </a>
            </nav>
            <div class="sidebar-card">
                <p><strong>Clinical flow</strong></p>
                <p>Track patients, departments, admissions, and beds from one calm workspace.</p>
            </div>
        </aside>
        <main class="main-panel">
            <header class="topbar">
                <p class="topbar-title">Hospital Management Console</p>
                <a class="login-link" href="/Account/Login">Login</a>
            </header>
            <div class="content-wrap">
                @RenderBody()
            </div>
        </main>
    </div>
</body>
</html>
